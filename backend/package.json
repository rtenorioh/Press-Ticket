{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "create": "npx sequelize-cli db:create",
    "migrate": "tsc && npx sequelize-cli db:migrate",
    "migrate:undo": "tsc && npx sequelize-cli db:migrate:undo",
    "sequelize": "npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
    "watch": "tsc -w",
    "start": "nodemon --watch dist --ignore .wwebjs_auth --ignore .wwebjs_cache --ignore logs dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only --ignore node_modules src/server.ts",
    "pretest": "NODE_ENV=test sequelize db:migrate && NODE_ENV=test sequelize db:seed:all",
    "test": "NODE_ENV=test jest",
    "posttest": "NODE_ENV=test sequelize db:migrate:undo:all",
    "swagger:template": "node scripts/generate-swagger-template.js",
    "lint": "eslint src"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.4.1",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "http-graceful-shutdown": "^3.1.16",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^2.1.35",
    "multer": "^2.1.1",
    "mustache": "^4.2.0",
    "mysql2": "^3.22.3",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.16",
    "notificamehubsdk": "^0.0.27",
    "openai": "^4.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "github:pedroslopez/whatsapp-web.js#main",
    "yup": "^1.7.1"
