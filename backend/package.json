    "@types/express-rate-limit": "^5.1.3",
    "@types/factory-girl": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^1.4.4",
    "@types/mustache": "^4.1.2",
